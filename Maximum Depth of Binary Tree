class Solution {
public:
    int solve(TreeNode* root){
        if(root==NULL){
            return 0;
        }
        int l=1+solve(root->left);
        int r=1+solve(root->right);
        return max(l,r);
    }
    int maxDepth(TreeNode* root) {
        int x=solve(root);
        return x;
    }
};
