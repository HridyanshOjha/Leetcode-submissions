class Solution {
public:
    void solve(int idx, int target, vector<int> &curr, vector<vector<int>> &ans, vector<int> &nums) {
        if (idx == nums.size()) {
        if (target == 0) {
            ans.push_back(curr);
        }
            return;
        }
        if (target >= nums[idx]) {
            curr.push_back(nums[idx]);
            solve(idx,  target - nums[idx],curr,ans,nums);
            curr.pop_back();
        }
        solve( idx + 1, target, curr, ans,nums);
    }

    vector<vector<int>> combinationSum(vector<int>& candidates, int target) {
        vector<vector<int>> ans;
        vector<int> curr;
        solve(0, target, curr, ans, candidates);
        return ans;
    }
};
