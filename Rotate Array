void rotate(vector<int>& arr, int k) {

        if(k==0 || k % arr.size()==0){return;}
        reverse(arr.begin(), arr.end());
         if(k>=arr.size()){
         k=k % arr.size() ;
            
        }
        reverse(arr.begin(), arr.begin() + k);
        reverse(arr.begin() + k, arr.end());
 
    }
