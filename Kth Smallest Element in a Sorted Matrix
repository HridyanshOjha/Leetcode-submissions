int kthSmallest(vector<vector<int>>& arr, int k) {
        int n = arr[0].size();
        priority_queue<int> pq;
        for (int i = 0; i < arr.size(); i++) {
            for (int j = 0; j < n; j++) {

                pq.push(arr[i][j]);
                if (pq.size() > k) {
                    pq.pop();
                }
            }
        }
        return pq.top();
    }
