 ListNode *getIntersectionNode(ListNode *fh, ListNode *sh) {
        if(fh==nullptr || sh==nullptr) return nullptr;
        ListNode* t1=fh;
        ListNode* t2=sh;
        while(t1!=t2){
            t1=t1->next;
            t2=t2->next;
            if(t1==t2){ return t1;}
            if(t1==nullptr) t1=sh;
            if(t2==nullptr) t2=fh;
        }
        return t1;
    }
