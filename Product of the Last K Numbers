class ProductOfNumbers {
public:
    vector<int> arr;
    ProductOfNumbers() {
        
    }
    
    void add(int num) {
        arr.push_back(num);
    }
    
    int getProduct(int k) {
        int s=arr.size()-1;
        int mul=1;
        for(int i=s ;s>=0;i--){
            mul*=arr[i];
            k--;
            if(k==0){
                break;
            }
        }
        return mul;
    }
};

