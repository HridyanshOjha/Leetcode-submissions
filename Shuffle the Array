class Solution {
public:
    vector<int> shuffle(vector<int>& nums, int n) {
        vector<int> ans(nums.size());
        for(int i=0;i<n;i++){
            ans[2*i]=nums[i];
        }
        int k=0;
        for(int i=n;i<nums.size();i++){
            ans[2*k+1]=nums[i];
            k++;
        }
        return ans;
    }
};
