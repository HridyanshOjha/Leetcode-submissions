   vector<int> getRow(int n) {
        vector<int > ans;
        long long  res = 1;
    // cout << res << " ";
    ans.push_back(1);
    if(n==0){return ans;}
    n=n+1;
    for (int j = 1; j < n; j++)
    {
        res = res * (n - j);
        res = res / j;
       ans.push_back(res);
    }
    return ans;
    }
